# Copy this file to .env and replace the placeholder hosts/IPs before deploying.

# Backend bind
HOST=0.0.0.0
PORT=8000

# Public HTTPS host for Caddy + browser clients
PUBLIC_HOST=spark.hivehub.org
PUBLIC_PORT=8443

# CORS accepts a comma-separated list or JSON array.
CORS_ORIGINS="https://spark.hivehub.org:8443,https://DGX_HOST_OR_IP:8443,https://localhost:8443,https://127.0.0.1:8443"

# LLM endpoint
# Use "lmstudio" for any OpenAI-compatible /v1 server.
LLM_PROVIDER=lmstudio
LLM_BASE_URL=http://DGX_HOST_OR_IP:1234/v1
LLM_API_KEY=lm-studio
LLM_MODEL_ID=qwen/qwen3.5-35b-a3b
FAST_LLM_MODEL_ID=qwen/qwen3.5-35b-a3b

# STT (faster-whisper on CUDA)
WHISPER_MODEL_ID=large-v3-turbo
WHISPER_DEVICE=auto
WHISPER_COMPUTE_TYPE=float16
WHISPER_BEAM_SIZE=1
WHISPER_BEST_OF=1
WHISPER_CPU_THREADS=8
WHISPER_NUM_WORKERS=2
WHISPER_CPP_ENABLED=1
WHISPER_CPP_MODEL_PATH=./third_party/whisper.cpp/models/ggml-base.en.bin

# TTS
TTS_BACKEND=piper
TTS_PROVIDER=piper
PIPER_BINARY=piper
PIPER_MODEL_PATH=./models/piper/en_US-lessac-high.onnx
PIPER_STYLE=fast

# Optional Qwen3-TTS CUDA fallback
# TTS_PROVIDER=qwen3_tts
# QWEN3_TTS_MODEL_ID=Qwen/Qwen3-TTS-1.7B
# QWEN3_TTS_ENGINE=faster
# QWEN3_TTS_STREAMING_ENABLED=1
# QWEN3_TTS_STREAM_CHUNK_SIZE=8
